# ==============================================>
# 0. TNG API — fetch real metallicity data
# ==============================================>

def fetch_tng_metallicity(api_key: str, n_halos: int = 50) -> np.ndarray | None:
    """
    Fetch stellar metallicities from IllustrisTNG TNG100-1 snapshot 99 (z=0).
    Returns array in solar units (Z/Z_sun, Z_sun=0.0127), or None on failure.
    """
    try:
        import requests
    except ImportError:
        warnings.warn("requests not installed — pip install requests")
        return None

    BASE    = "https://www.tng-project.org/api/"
    headers = {"api-key": api_key}

    r = requests.get(BASE, headers=headers, timeout=10)
    if r.status_code != 200:
        warnings.warn(f"TNG auth failed: HTTP {r.status_code}")
        return None

    url    = f"{BASE}TNG100-1/snapshots/99/subhalos/"
    params = {"limit": n_halos, "stellar_metallicity__gt": 0.001,
              "order_by": "-mass_stars"}
    r = requests.get(url, headers=headers, params=params, timeout=30)
    if r.status_code != 200:
        warnings.warn(f"TNG query failed: HTTP {r.status_code}")
        return None

    results = r.json().get("results", [])
    metallicities = []
    for halo in results:
        d = requests.get(halo["url"], headers=headers, timeout=10)
        if d.status_code == 200:
            z = d.json().get("stellar_metallicity")
            if z is not None:
                metallicities.append(z)

    if not metallicities:
        return None

    z_array = np.array(metallicities) / 0.0127
    print(f"TNG fetch: {len(z_array)} halos | "
          f"Z={z_array.min():.3f}–{z_array.max():.3f} Z☉ | "
          f"mean={z_array.mean():.3f} Z☉")
    return z_array


# ==============================================>
# 1. UV ACTIVITY DECAY MODEL (vectorized)
# ==============================================>

def uv_flare_denom_vec(star_types: np.ndarray,
                       ages: np.ndarray,
                       atm_depth_bar: float = 1.0) -> np.ndarray:
    """
    Vectorized per-star effective flare_denom from UV decay physics.

    M dwarfs: L_UV ~ t^(-0.5) after 1 Gyr saturation.
              flare_denom grows with age as atmosphere wins the arms race.
    K dwarfs: fixed 8.0  (moderate, stable)
    F/G:      fixed 12.0 (low intrinsic flare activity)
    """
    n        = len(star_types)
    result   = np.full(n, 12.0)   # F/G default

    is_K = star_types == 'K'
    is_M = star_types == 'M'

    result[is_K] = 8.0

    # M: activity decays as max(1, age)^(-0.5)
    t_clamped      = np.maximum(ages[is_M], 1.0)
    activity       = t_clamped ** -0.5
    base_denom     = 2.0
    denom_M        = np.clip(base_denom / activity * atm_depth_bar, 0.5, 50.0)
    result[is_M]   = denom_M

    return result


# ==============================================>
# 2. CORE SIMULATION ENGINE (fully vectorized)
# ==============================================>

def _draw_ages(star_types: np.ndarray, rng: np.random.Generator) -> np.ndarray:
    n   = len(star_types)
    ages = np.zeros(n)
    is_FG = star_types == 'F/G'
    is_K  = star_types == 'K'
    is_M  = star_types == 'M'
    ages[is_FG] = rng.uniform(1.0,   10.0,  is_FG.sum())
    ages[is_K]  = rng.uniform(2.0,   20.0,  is_K.sum())
    ages[is_M]  = rng.uniform(1.0,  100.0,  is_M.sum())
    return ages


def compute_habitability(star_types: np.ndarray,
                         p_planet:   np.ndarray,
                         ages:       np.ndarray,
                         cfg:        dict,
                         rng:        np.random.Generator) -> np.ndarray:
    """
    Fully vectorized habitability scores.

    IMPORTANT: flare_denom ONLY penalises M dwarfs.
    F/G and K have independent base habitability unaffected by flare_denom.
    This matches the physical motivation: F/G and K stars are not flare-dominated.

    FIX 2 applied: swapped base ranges so F/G has highest mean, K moderate, M wide.
    FIX 3 applied: sharper M flare penalty with tanh centred at fd=2.0.
    """
    n     = len(star_types)
    is_FG = star_types == 'F/G'
    is_K  = star_types == 'K'
    is_M  = star_types == 'M'

    # Base habitability per type — three independent draws
    base = np.zeros(n)
    base[is_FG] = rng.uniform(0.50, 1.00, int(is_FG.sum()))  # F/G: most stable
    base[is_K]  = rng.uniform(0.30, 0.80, int(is_K.sum()))   # K: moderate
    base[is_M]  = rng.uniform(0.05, 0.95, int(is_M.sum()))   # M: high ceiling, flare-gated

    # Effective flare_denom per star
    if cfg.get("use_uv_decay", False):
        fd_vec = uv_flare_denom_vec(star_types, ages,
                                    atm_depth_bar=cfg.get("atm_depth", 1.0))
    else:
        fd_scalar = cfg.get("flare_denom", 1.0)
        fd_vec    = np.full(n, fd_scalar)

    # Flare penalty — M DWARFS ONLY with sharpened tanh
    m_pen       = cfg.get("m_penalty", 1.0)
    flare_pen   = np.ones(n)
    # FIX 3: new tanh with midpoint fd=2.0, slope 1/1.2
    flare_pen[is_M] = (np.tanh((fd_vec[is_M] - 2.0) / 1.2) * 0.5 + 0.5) * m_pen

    hab = base * p_planet * flare_pen

    # Optional sigmoidal criticality filter
    k_sig = cfg.get("sigmoid_k", None)
    if k_sig is not None:
        mid  = cfg.get("sigmoid_mid", 0.4)
        sig  = 1.0 / (1.0 + np.exp(-k_sig * (hab - mid)))
        hab  = hab * sig

    return hab


def simulate(cfg: dict) -> dict:
    """
    Run one experiment. Returns raw arrays for analyze().
    """
    # FIX 1: per-experiment seed to avoid identical draws
    rng  = np.random.default_rng(cfg["seed"] + cfg.get("exp", 0) * 7919)
    n    = cfg["N"]

    # Stellar type draw (standard IMF)
    star_types = rng.choice(['F/G', 'K', 'M'], size=n, p=[0.15, 0.20, 0.65])

    # Stellar ages
    ages = _draw_ages(star_types, rng)

    # Metallicity: TNG real data or analytic log-normal
    tng_z = cfg.get("tng_z_array", None)
    if tng_z is not None:
        z_sample = rng.choice(tng_z, size=n, replace=True)
    else:
        z_sample = np.clip(rng.lognormal(0.0, 0.3, n), 0.05, 5.0)

    # Planet formation probability
    pg       = cfg.get("pg_base", 0.5)
    p_planet = np.clip(pg * z_sample, 0.05, 1.0)

    # Habitability
    hab = compute_habitability(star_types, p_planet, ages, cfg, rng)

    # Observer threshold
    threshold = cfg.get("hab_threshold", 0.5)
    observers = hab > threshold

    # Optional Phi-consciousness filter (Exp 4)
    phi_thresh = cfg.get("phi_threshold", None)
    if phi_thresh is not None:
        phi = np.where(is_type(star_types, 'K'),  rng.uniform(0.6, 1.0, n),
              np.where(is_type(star_types, 'F/G'), rng.uniform(0.3, 0.8, n),
                                                   rng.uniform(0.05, 0.5, n)))
        conscious = observers & (phi > phi_thresh)
    else:
        conscious = observers

    cosmic_ages = ages[conscious]

    return {
        "star_types":  star_types,
        "ages":        ages,
        "z_sample":    z_sample,
        "hab":         hab,
        "observers":   observers,
        "conscious":   conscious,
        "cosmic_ages": cosmic_ages,
        "p_planet":    p_planet,
        "cfg":         cfg,
    }


def is_type(arr, t):
    return arr == t


# ==============================================>
# 3. ANALYSIS & PLOTTING
# ==============================================>

def analyze(R: dict, cfg: dict) -> dict:
    st    = R["star_types"]
    obs   = R["observers"]
    con   = R["conscious"]
    ages  = R["cosmic_ages"]
    n     = cfg["N"]
    label = cfg["label"]
    exp   = cfg.get("exp", "?")

    print("=" * 50)
    print(f"EXPERIMENT {exp}: {label}")
    print("=" * 50)
    print(f"Samples: {n} | Observers: {obs.sum()} ({obs.mean()*100:.2f}%)")

    phi_on = cfg.get("phi_threshold") is not None
    if phi_on:
        print(f"Conscious: {con.sum()} ({con.mean()*100:.2f}%)")

    active = con if phi_on else obs
    type_counts = {t: (st[active] == t).sum() for t in ['F/G', 'K', 'M']}
    total_active = active.sum()
    print("Stellar type distribution:")
    for t, c in sorted(type_counts.items(), key=lambda x: -x[1]):
        pct = 100 * c / total_active if total_active > 0 else 0
        print(f"  {t:<4}: {c:5d} ({pct:.1f}%)")

    if len(ages) > 0:
        print(f"Cosmic age: mean={ages.mean():.1f}, "
              f"median={np.median(ages):.1f}, std={ages.std():.1f}")

    mean_z = R["z_sample"][active].mean() if total_active > 0 else float('nan')

    # Plot
    fig, axes = plt.subplots(1, 3, figsize=(15, 4))
    fig.suptitle(f"Exp {exp}: {label}", fontsize=13)

    axes[0].hist(R["hab"], bins=50, color='steelblue', alpha=0.7)
    axes[0].axvline(cfg.get("hab_threshold", 0.5), color='red',
                    linestyle='--', label='threshold')
    axes[0].set_xlabel("Habitability Score")
    axes[0].set_title("Habitability Distribution")
    axes[0].legend()

    labels_pie = [t for t in ['F/G', 'K', 'M'] if type_counts[t] > 0]
    sizes_pie  = [type_counts[t] for t in labels_pie]
    colors_pie = {'F/G': '#FFD700', 'K': '#FFA500', 'M': '#CC3333'}
    if sizes_pie:
        axes[1].pie(sizes_pie,
                    labels=labels_pie,
                    colors=[colors_pie[t] for t in labels_pie],
                    autopct='%1.1f%%', startangle=140)
    axes[1].set_title("Observer Stellar Types")

    if len(ages) > 0:
        axes[2].hist(ages, bins=30, color='purple', alpha=0.7)
        axes[2].axvline(ages.mean(), color='white', linestyle='--',
                        label=f'mean={ages.mean():.1f} Gyr')
        axes[2].set_xlabel("Stellar Age (Gyr)")
        axes[2].set_title("Cosmic Age Distribution")
        axes[2].legend()

    plt.tight_layout()
    fname = f"exp_{exp}.png"
    plt.savefig(fname, dpi=120)
    plt.close()
    print(f"Saved: {fname}")

    stats = {
        "exp": exp, "label": label,
        "n_samples": n, "n_observers": int(obs.sum()),
        "yield_pct": round(obs.mean() * 100, 2),
        "n_conscious": int(con.sum()),
        "conscious_pct": round(con.mean() * 100, 2),
        "FG_pct":  round(100 * type_counts['F/G'] / total_active, 1) if total_active else 0,
        "K_pct":   round(100 * type_counts['K']   / total_active, 1) if total_active else 0,
        "M_pct":   round(100 * type_counts['M']   / total_active, 1) if total_active else 0,
        "mean_age_gyr": round(float(ages.mean()), 2) if len(ages) else None,
        "mean_z_solar": round(float(mean_z), 3),
    }
    with open(f"exp_{exp}_stats.json", "w") as f:
        json.dump(stats, f, indent=2)
    return stats


# ==============================================>
# 4. FLARE_DENOM SWEEP (Exp 6)
# ==============================================>

def run_sweep(n: int = 20000, seed: int = 42):
    """Phase transition diagram. Sweep from fd=1.0 to recover original transition at ~2.5."""
    print("\n>>> EXPERIMENT 6: Flare-denom sweep <<<")

    # logspace(0, 2, 25) = 1.0 → 100.0 — matches original range
    denoms = np.logspace(0, 2, 25)
    fg_list, k_list, m_list = [], [], []

    for fd in denoms:
        cfg = {
            "N": n, "seed": seed, "label": "sweep",
            "flare_denom": float(fd), "pg_base": 0.5,
            "hab_threshold": 0.5,
        }
        R   = simulate(cfg)
        obs = R["observers"]
        st  = R["star_types"]
        total = obs.sum()
        if total == 0:
            fg_list.append(0); k_list.append(0); m_list.append(0)
            continue
        fg_list.append(100 * (st[obs] == 'F/G').mean())
        k_list.append( 100 * (st[obs] == 'K').mean())
        m_list.append( 100 * (st[obs] == 'M').mean())
        print(f"  flare_denom={fd:6.1f} -> "
              f"F/G={fg_list[-1]:.1f}%, "
              f"M={m_list[-1]:.1f}%, "
              f"K={k_list[-1]:.1f}%")

    fig, ax = plt.subplots(figsize=(10, 5))
    ax.semilogx(denoms, fg_list, 'o-', color='#FFD700', label='F/G')
    ax.semilogx(denoms, k_list,  's-', color='#FFA500', label='K')
    ax.semilogx(denoms, m_list,  '^-', color='#CC3333', label='M')
    ax.axvline(2.5, color='white', linestyle='--', alpha=0.8,
               label='Critical transition ≈ 2.5')
    ax.set_xlabel("flare_denom (log scale)")
    ax.set_ylabel("% of Observers")
    ax.set_title("Phase Transition of Habitability (Exp 6 Sweep)")
    ax.legend(); ax.grid(True, alpha=0.3)
    plt.tight_layout()
    plt.savefig("exp_6_sweep.png", dpi=120)
    plt.close()
    print("Saved: exp_6_sweep.png")


